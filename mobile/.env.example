# ─────────────────────────────────────────────────────────────
# LingvaUZ mobile — API URL configuration
# ─────────────────────────────────────────────────────────────
#
# Default below targets the public staging API so `npm run tunnel`
# works out-of-the-box even when the phone is on a different network.
#
# 1) Tunnel mode (`npm run tunnel`) — phone on different network:
#    Keep the public URL below, OR run `ngrok http 3001` for your
#    local backend and replace with the ngrok URL.
#       EXPO_PUBLIC_API_URL=https://abcd1234.ngrok-free.app/api
#
# 2) LAN mode (`npm run start`) — phone & PC on the SAME WiFi:
#    Use your PC's LAN IPv4 (`ipconfig` on Windows).
#       EXPO_PUBLIC_API_URL=http://192.168.1.42:3001/api
#
# 3) Local web preview (`npm run web`):
#       EXPO_PUBLIC_API_URL=http://localhost:3001/api
#
# Notes:
# - Must start with EXPO_PUBLIC_ prefix or Expo strips it from the bundle.
# - After editing this file you MUST restart Metro (`r` is not enough).

EXPO_PUBLIC_API_URL=https://lingvauz-api.onrender.com/api

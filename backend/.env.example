# PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lingvauz?schema=public"

# Auth
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="30d"
BCRYPT_ROUNDS=10

# Google Sign-In (https://console.cloud.google.com → APIs &amp; Services → Credentials)
GOOGLE_CLIENT_ID="123456789-xxxxxxxxxxxx.apps.googleusercontent.com"

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
